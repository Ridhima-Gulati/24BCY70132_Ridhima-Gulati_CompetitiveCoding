#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<pair<int,int>> edges(n-1);
    vector<int> deg(n+1, 0);

    for (int i = 0; i < n-1; i++) {
        cin >> edges[i].first >> edges[i].second;
        deg[edges[i].first]++;
        deg[edges[i].second]++;
    }

    int center = -1;

    for (int i = 1; i <= n; i++) {
        if (deg[i] >= 3) {
            center = i;
            break;
        }
    }

    vector<int> ans(n-1);
    int label = 0;

    if (center != -1) {
        for (int i = 0; i < n-1; i++) {
            if (edges[i].first == center || edges[i].second == center) {
                ans[i] = label++;
            }
        }
      
        for (int i = 0; i < n-1; i++) {
            if (edges[i].first != center && edges[i].second != center) {
                ans[i] = label++;
            }
        }
    } else {
        for (int i = 0; i < n-1; i++) {
            ans[i] = i;
        }
    }

    for (int x : ans) cout << x << "\n";

    return 0;
}
