#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> a(n);
    int totalOnes = 0;

    for (int i = 0; i < n; i++) {
        cin >> a[i];
        if (a[i] == 1) totalOnes++;
    }

    int maxSum = -1e9, currentSum = 0;

    for (int i = 0; i < n; i++) {
        int val = (a[i] == 0) ? 1 : -1;

        currentSum = max(val, currentSum + val);
        maxSum = max(maxSum, currentSum);
    }

    cout << totalOnes + maxSum << endl;

    return 0;
}
